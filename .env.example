# EmailJS Configuration
# Get these from https://dashboard.emailjs.com/

# Your EmailJS Public Key
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here

# EmailJS Service ID
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id_here

# EmailJS Template ID (for admin notifications)
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id_here

# EmailJS Confirmation Template ID (for applicant confirmation)
VITE_EMAILJS_CONFIRMATION_TEMPLATE=your_emailjs_confirmation_template_id_here

# Important: Copy this file to .env.local and fill in your actual credentials
# DO NOT commit .env.local to git
